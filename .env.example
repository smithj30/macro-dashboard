# FRED API Key
# Get yours at https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_api_key_here

# BEA API Key (required for Investment & Construction chart)
# Register at https://apps.bea.gov/api/signup/
BEA_API_KEY=your_bea_api_key_here

# RapidAPI Key (required for news feeds on dashboards)
# Subscribe to "Reuters Business and Financial News" at rapidapi.com
RAPIDAPI_KEY=your_rapidapi_key_here
